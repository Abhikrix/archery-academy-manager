rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userProfilePath());
    }

    function currentUserProfile() {
      return get(userProfilePath()).data;
    }

    function validRole(role) {
      return role in ['admin', 'coach', 'student'];
    }

    function isAdmin() {
      return hasUserProfile() && currentUserProfile().role == 'admin';
    }

    function isCoach() {
      return hasUserProfile() && currentUserProfile().role == 'coach';
    }

    function isStudent() {
      return hasUserProfile() && currentUserProfile().role == 'student';
    }

    function isStaff() {
      return isAdmin() || isCoach();
    }

    function linkedStudentId() {
      return request.auth.uid;
    }

    function isOwnStudentRecord(studentId) {
      return isStudent() && linkedStudentId() == studentId;
    }

    function studentExists(studentId) {
      return exists(/databases/$(database)/documents/students/$(studentId));
    }

    function validUserProfile(userId) {
      return request.resource.data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt'])
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'role',
          'createdAt',
          'studentId'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && validRole(request.resource.data.role)
        && request.resource.data.createdAt is timestamp
        && (
          !request.resource.data.keys().hasAny(['studentId'])
          || (
            request.resource.data.role == 'student'
            && request.resource.data.studentId is string
          )
        );
    }

    function validStudentRecord(studentId) {
      return request.resource.data.keys().hasAll([
          'id',
          'studentId',
          'name',
          'batch',
          'parentName',
          'parentPhone',
          'parentPhoneNumber',
          'studentPhone',
          'studentPhoneNumber',
          'batchId',
          'monthlyFee',
          'pendingFees',
          'feeAmount',
          'dateOfBirth',
          'joinDate',
          'feeStatus',
          'attendanceStatus',
          'attendanceRate',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'id',
          'studentId',
          'name',
          'batch',
          'parentName',
          'parentPhone',
          'parentPhoneNumber',
          'studentPhone',
          'studentPhoneNumber',
          'batchId',
          'monthlyFee',
          'pendingFees',
          'feeAmount',
          'dateOfBirth',
          'joinDate',
          'feeStatus',
          'attendanceStatus',
          'attendanceRate',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == studentId
        && request.resource.data.studentId == studentId
        && request.resource.data.name is string
        && request.resource.data.batch is string
        && request.resource.data.parentName is string
        && request.resource.data.parentPhone is string
        && request.resource.data.parentPhoneNumber is string
        && request.resource.data.studentPhone is string
        && request.resource.data.studentPhoneNumber is string
        && request.resource.data.batchId is string
        && request.resource.data.batch == request.resource.data.batchId
        && request.resource.data.feeAmount is number
        && request.resource.data.feeAmount >= 0
        && request.resource.data.monthlyFee is number
        && request.resource.data.monthlyFee >= 0
        && request.resource.data.monthlyFee == request.resource.data.feeAmount
        && request.resource.data.pendingFees is number
        && request.resource.data.pendingFees >= 0
        && request.resource.data.parentPhone == request.resource.data.parentPhoneNumber
        && request.resource.data.studentPhone == request.resource.data.studentPhoneNumber
        && request.resource.data.dateOfBirth is string
        && request.resource.data.joinDate is string
        && request.resource.data.joinDate == request.resource.data.dateOfBirth
        && request.resource.data.feeStatus in ['paid', 'pending']
        && request.resource.data.attendanceStatus in ['present', 'absent']
        && request.resource.data.attendanceRate is number
        && request.resource.data.attendanceRate >= 0
        && request.resource.data.attendanceRate <= 100
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validAttendanceRecord(recordId) {
      return request.resource.data.keys().hasAll([
          'studentId',
          'date',
          'status',
          'markedAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'studentId',
          'date',
          'status',
          'markedAt',
          'updatedAt'
        ])
        && request.resource.data.studentId is string
        && request.resource.data.date is string
        && request.resource.data.status in ['present', 'absent']
        && request.resource.data.markedAt == request.time
        && request.resource.data.updatedAt == request.time
        && recordId == request.resource.data.studentId + '_' + request.resource.data.date
        && studentExists(request.resource.data.studentId);
    }

    function validFeeRecord(recordId) {
      return request.resource.data.keys().hasAll([
          'studentId',
          'studentName',
          'month',
          'amount',
          'amountPaid',
          'dueAmount',
          'status',
          'paymentDate',
          'notes',
          'updatedBy',
          'timestamp'
        ])
        && request.resource.data.keys().hasOnly([
          'studentId',
          'studentName',
          'month',
          'amount',
          'amountPaid',
          'dueAmount',
          'status',
          'paymentDate',
          'notes',
          'updatedBy',
          'timestamp'
        ])
        && request.resource.data.studentId is string
        && request.resource.data.studentName is string
        && request.resource.data.month is string
        && request.resource.data.amount is number
        && request.resource.data.amountPaid is number
        && request.resource.data.dueAmount is number
        && request.resource.data.amount >= 0
        && request.resource.data.amountPaid >= 0
        && request.resource.data.amountPaid <= request.resource.data.amount
        && request.resource.data.dueAmount == request.resource.data.amount - request.resource.data.amountPaid
        && request.resource.data.status in ['paid', 'pending']
        && (
          (request.resource.data.status == 'paid' && request.resource.data.dueAmount == 0)
          || (request.resource.data.status == 'pending' && request.resource.data.dueAmount > 0)
        )
        && request.resource.data.paymentDate is string
        && request.resource.data.notes is string
        && request.resource.data.updatedBy is string
        && request.resource.data.timestamp == request.time
        && recordId == request.resource.data.studentId + '_' + request.resource.data.month
        && studentExists(request.resource.data.studentId);
    }

    function validEquipmentPurchaseRecord() {
      return request.resource.data.keys().hasAll([
          'itemName',
          'category',
          'studentId',
          'studentName',
          'totalPrice',
          'paidAmount',
          'dueAmount',
          'purchaseDate',
          'paymentStatus',
          'notes',
          'updatedBy',
          'timestamp'
        ])
        && request.resource.data.keys().hasOnly([
          'itemName',
          'category',
          'studentId',
          'studentName',
          'totalPrice',
          'paidAmount',
          'dueAmount',
          'purchaseDate',
          'paymentStatus',
          'notes',
          'updatedBy',
          'timestamp'
        ])
        && request.resource.data.itemName is string
        && request.resource.data.category is string
        && request.resource.data.studentId is string
        && request.resource.data.studentName is string
        && request.resource.data.totalPrice is number
        && request.resource.data.paidAmount is number
        && request.resource.data.dueAmount is number
        && request.resource.data.totalPrice > 0
        && request.resource.data.paidAmount >= 0
        && request.resource.data.paidAmount <= request.resource.data.totalPrice
        && request.resource.data.dueAmount == request.resource.data.totalPrice - request.resource.data.paidAmount
        && request.resource.data.paymentStatus in ['paid', 'pending']
        && (
          (request.resource.data.paymentStatus == 'paid' && request.resource.data.dueAmount == 0)
          || (request.resource.data.paymentStatus == 'pending' && request.resource.data.dueAmount > 0)
        )
        && request.resource.data.purchaseDate is string
        && request.resource.data.notes is string
        && request.resource.data.updatedBy is string
        && request.resource.data.timestamp == request.time
        && studentExists(request.resource.data.studentId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if signedIn()
        && validUserProfile(userId)
        && request.resource.data.createdAt == request.time
        && (
          (
            request.auth.uid == userId
            && request.resource.data.email == request.auth.token.email
            && request.resource.data.role == 'student'
          )
          || isAdmin()
        );

      allow update: if isAdmin()
        && validUserProfile(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && (request.auth.uid != userId || request.resource.data.role == 'admin');

      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isCoach() || isOwnStudentRecord(studentId);

      allow create: if isAdmin()
        && validStudentRecord(studentId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isAdmin()
        && validStudentRecord(studentId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isStaff() || isOwnStudentRecord(resource.data.studentId);

      allow create: if isStaff() && validAttendanceRecord(recordId);

      allow update: if isStaff()
        && validAttendanceRecord(recordId)
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.date == resource.data.date;

      allow delete: if isAdmin();
    }

    match /fees/{recordId} {
      allow read: if isStaff() || isOwnStudentRecord(resource.data.studentId);

      allow create: if isStaff() && validFeeRecord(recordId);

      allow update: if isStaff()
        && validFeeRecord(recordId)
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.month == resource.data.month;

      allow delete: if isAdmin();
    }

    match /equipmentPurchases/{purchaseId} {
      allow read: if isStaff() || isOwnStudentRecord(resource.data.studentId);

      allow create: if isStaff() && validEquipmentPurchaseRecord();

      allow update: if isStaff()
        && validEquipmentPurchaseRecord();

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
